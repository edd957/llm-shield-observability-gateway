LLM_SHIELD_API_KEYS=dev-proxy-key
LLM_SHIELD_PRIMARY_MODEL=openai/gpt-4o-mini
LLM_SHIELD_FALLBACK_MODELS=openai/gpt-4.1-mini,anthropic/claude-3-5-haiku-latest
LLM_SHIELD_OPENAI_API_KEY=replace-me
LLM_SHIELD_ANTHROPIC_API_KEY=replace-me
LLM_SHIELD_DATABASE_URL=postgresql+asyncpg://llm_shield:llm_shield@postgres:5432/llm_shield
LLM_SHIELD_ENABLE_TRANSFORMER_GUARD=false
LLM_SHIELD_PROMPT_INJECTION_MODEL=protectai/deberta-v3-base-prompt-injection-v2
LLM_SHIELD_REQUEST_TIMEOUT_SECONDS=60
LLM_SHIELD_LOG_LEVEL=INFO
